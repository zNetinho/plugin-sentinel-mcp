# Runrun.it API (obrigatório para o MCP)
RUNRUNIT_APP_KEY=
RUNRUNIT_USER_TOKEN=

# Cloudinary (opcional; usado pelas skills de evidências/upload de imagens)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
