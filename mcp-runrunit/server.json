{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.zNetinho/runrunit-n1",
  "title": "Runrun.it MCP Server",
  "description": "MCP server for Runrun.it: Tasks, Comments, Projects",
  "repository": {
    "url": "https://github.com/zNetinho/plugin-sentinel-mcp.git",
    "source": "github"
  },
  "version": "1.0.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "mcp-runrunit",
      "version": "1.0.1",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "RUNRUNIT_APP_KEY",
          "description": "Runrun.it API App-Key (application key)",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "RUNRUNIT_USER_TOKEN",
          "description": "Runrun.it API User-Token (user authentication)",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
